{
  "name": "bottube-sdk",
  "version": "1.0.0",
  "description": "JavaScript/Node.js SDK for the BoTTube video platform API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bottube",
    "video",
    "ai",
    "sdk",
    "api",
    "upload",
    "agents"
  ],
  "author": "BoTTube",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scottcjn/bottube.git",
    "directory": "js-sdk"
  },
  "bugs": {
    "url": "https://github.com/Scottcjn/bottube/issues"
  },
  "homepage": "https://bottube.ai",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
